---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="flex flex-col gap-6 pt-8 md:gap-8 md:pt-10">
    <h1 class="text-2xl font-light md:text-4xl">
      ¡Hola, soy <strong class="font-manrope text-orange-9 font-bold"
        >Jair Ochoa</strong
      >!
    </h1>
    <p class="font-light md:text-2xl">
      Diseñador y desarrollador web enfocado en crear soluciones digitales
      efectivas, centradas en la experiencia del usuario.
    </p>
    <aside class="flex gap-2 font-light md:text-2xl">
      <h2>Actualmente:</h2>
      <p class="text-orange-9 font-medium">Freelance</p>
    </aside>
  </section>

  <section></section>
</Layout>
