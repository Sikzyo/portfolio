---
import "@styles/global.css";
import "@fontsource-variable/manrope";
import "@fontsource-variable/sora";
import Header from "@components/layout/Header.astro";

const { title, description } = Astro.props;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/about", label: "Sobre mí" },
  { href: "/hoja-de-vida", label: "Hoja de vida" },
];
---

<!doctype html>
<html lang="es">
  <head>
    <!-- TODO SEO: Agregar canonical URL -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <!-- TODO SEO: Agregar Open Graph tags (og:title, og:description, og:image, og:url) -->
    <!-- TODO SEO: Agregar Twitter Cards -->
    <!-- TODO SEO: Agregar JSON-LD (Schema.org) para portfolio -->
    <!-- TODO SEO: Agregar theme-color para móvil -->
    <!-- TODO SEO: Agregar format-detection -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="font-sora from-orange-1 to-blue-3 flex min-h-screen flex-col items-center gap-8 bg-linear-to-b p-6 md:gap-10 md:p-8"
  >
    <Header links={links} />
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100vh;
  }
</style>
